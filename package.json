{
  "name": "soundcloud-sync",
  "version": "2.0.1",
  "main": "public/electron.js",
  "scripts": {
    "start": "electron .",
    "build-mac": "electron-builder --mac"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-is-dev": "^1.2.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.soundcloud-sync.app",
    "productName": "SoundCloud Sync",
    "files": [
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": ".",
        "filter": [
          "sync_bin",
          "sync_spotify_bin",
          "ffmpeg"
        ]
      }
    ],
    "asar": false,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "icon.icns"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
